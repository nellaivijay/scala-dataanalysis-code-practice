# Scala Data Analysis Code Practice Environment Configuration

# Scala/Spark Configuration
SCALA_VERSION=2.10.4
SPARK_VERSION=1.6.0
SBT_VERSION=0.13.8
JAVA_VERSION=1.7

# Spark Configuration
SPARK_MASTER_URL=spark://localhost:7077
SPARK_MASTER_UI_PORT=8080
SPARK_MASTER_PORT=7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2

# Spark History Server Configuration
SPARK_HISTORY_PORT=18080
SPARK_EVENT_LOG_DIR=file:///tmp/spark-events

# Breeze Configuration
BREEZE_VERSION=0.13

# Apache Zeppelin Configuration (for visualization chapters)
ZEPPELIN_PORT=8080
ZEPPELIN_HOME=/opt/zeppelin

# Kafka Configuration (for streaming chapters)
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=localhost:2181
KAFKA_ADVERTISED_LISTENERS=localhost:9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_LOG_RETENTION_HOURS=168

# Zookeeper Configuration (for Kafka)
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Twitter API Configuration (for streaming chapters)
TWITTER_CONSUMER_KEY=your_consumer_key_here
TWITTER_CONSUMER_SECRET=your_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Network Configuration
SCALA_DATA_ANALYSIS_NETWORK=scala-data-analysis-network

# Paths
PROJECT_DIR=/home/ramdov/projects/scala-dataanalysis-code-practice
DATA_DIR=/home/ramdov/projects/scala-dataanalysis-code-practice/data
SOLUTIONS_DIR=/home/ramdov/projects/scala-dataanalysis-code-practice/solutions
NOTEBOOKS_DIR=/home/ramdov/projects/scala-dataanalysis-code-practice/notebooks
LOG_DIR=/home/ramdov/projects/scala-dataanalysis-code-practice/logs

# Dataset Configuration
NUM_SAMPLES=1000
DATA_FORMAT=csv

# Resource Limits
SPARK_MASTER_MEMORY=1Gi
SPARK_MASTER_CPU=500m
SPARK_WORKER_MEMORY=2Gi
SPARK_WORKER_CPU=1000m
ZEPPELIN_MEMORY=2Gi
ZEPPELIN_CPU=1000m

# Build Configuration
BUILD_MODE=local
DEPLOY_MODE=local

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=pattern

# MLlib Configuration (for machine learning chapters)
MLLIB_NUM_ITERATIONS=100
MLLIB_REGULARIZATION_PARAM=0.01
MLLIB_STEP_SIZE=0.001

# GraphX Configuration (for graph processing chapters)
GRAPHX_PARTITIONS=10
GRAPHX_STORAGE_LEVEL=MEMORY_ONLY